{
  "extends": "@tsconfig/recommended/tsconfig.json",
  "compilerOptions": {
    "lib": ["es2024", "dom"],
    "target": "es2024",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "jsx": "react-jsx",
    "types": ["node", "mocha"],
    "declaration": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "noEmit": true
  },
  "include": ["src", "test"]
}
